# WindSentinel server environment example
WINDSENTINEL_DEBUG=true
WINDSENTINEL_LOG_LEVEL=INFO
WINDSENTINEL_LOG_REQUEST_BODY=false
WINDSENTINEL_MFA_ISSUER=WindSentinel

# PostgreSQL
WINDSENTINEL_DB_HOST=127.0.0.1
WINDSENTINEL_DB_PORT=5432
WINDSENTINEL_DB_NAME=windsentinel
WINDSENTINEL_DB_USER=windsentinel
WINDSENTINEL_DB_PASSWORD=windsentinel
WINDSENTINEL_DB_SSLMODE=prefer
# Alternatively use a single DSN / URL:
# WINDSENTINEL_POSTGRES_DSN=dbname=windsentinel user=windsentinel password=windsentinel host=127.0.0.1 port=5432 sslmode=prefer
# WINDSENTINEL_DATABASE_URL=postgresql://windsentinel:windsentinel@127.0.0.1:5432/windsentinel

# Development server run options (useful on macOS and Linux)
WINDSENTINEL_SERVER_HOST=127.0.0.1
WINDSENTINEL_SERVER_PORT=8000
WINDSENTINEL_SERVER_RELOAD=1
