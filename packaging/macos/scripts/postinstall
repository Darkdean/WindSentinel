#!/usr/bin/env bash
set -euo pipefail
PLIST="/Library/LaunchDaemons/com.windsentinel.agent.plist"
if [[ -f "$PLIST" ]]; then
  launchctl bootstrap system "$PLIST" >/dev/null 2>&1 || true
  launchctl enable system/com.windsentinel.agent >/dev/null 2>&1 || true
  launchctl kickstart -k system/com.windsentinel.agent >/dev/null 2>&1 || true
fi
